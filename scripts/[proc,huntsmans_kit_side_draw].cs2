// 5002
[proc,huntsmans_kit_side_draw](int $comsubid0, component $com_huntsmans_kit_side_items1)
def_obj $obj2 = null;
def_int $comsubid3 = 0;
while ($comsubid3 < $comsubid0) {
	if (cc_find($com_huntsmans_kit_side_items1, $comsubid3) = true) {
		cc_clearops;
		cc_setontimer(null);
		cc_setposition(calc($comsubid3 % 4 * 42), calc($comsubid3 / 4 * 36), ^setpos_abs_left, ^setpos_abs_top);
		$obj2 = inv_getobj(inv, $comsubid3);
		if ($obj2 ! null) {
			~huntsmans_kit_setsideitem($obj2, inv_getnum(inv, $comsubid3), $comsubid0);
		} else {
			~huntsmans_kit_setblank;
		}
	}
	$comsubid3 = calc($comsubid3 + 1);
}
