// 1501
[proc,soul_wars_clan_games_button_draw](component $component0, int $int1)
if (%soul_wars_clan_challenge_accept = 1) {
	~soul_wars_clan_games_confirm_pressed($component0, "Waiting", 0);
} else if ($int1 = 1) {
	~soul_wars_clan_games_confirm_pressed($component0, "Confirm", 1);
} else {
	~soul_wars_clan_games_confirm_notpressed($component0, "Confirm", 1);
}
