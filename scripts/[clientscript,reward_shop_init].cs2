// 6082
[clientscript,reward_shop_init]
def_component $component0 = giants_foundry_reward_shop:infinity;
if_setontimer("responsive_interface_scaler($component0, -1)", $component0);
if_setonresize("giants_foundry_reward_shop_setup(1)", $component0);
if_setonvartransmit("giants_foundry_reward_shop_setup(0){giants_foundry_reward_shop_points}", $component0);
