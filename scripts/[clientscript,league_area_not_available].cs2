// 3676
[clientscript,league_area_not_available](int $int0, string $string0)
if (string_length($string0) < 1) {
	$string0 = "That area is unavailable.";
}
sound_synth(pillory_wrong, 1, 0);
if ($int0 = 1) {
	mes("<col=ff0000>You have already unlocked this area.");
} else if ($int0 = 0) {
	mes("<col=ff0000>You need to complete more tasks to unlock this area.");
} else if ($int0 = 3) {
	mes("<col=ff0000><$string0>");
} else if ($int0 = 4) {
	mes("<col=ff0000>You cannot unlock any more areas.");
}
