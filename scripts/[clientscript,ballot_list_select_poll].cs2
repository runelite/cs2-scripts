// 8330
[clientscript,ballot_list_select_poll](component $component0, int $comsubid1, int $int2, string $string0)
sound_synth(interface_select1, 1, 0);
if (cc_find($component0, $comsubid1) = true & cc_find($component0, cc_param(param_2359)) = true) {
	cc_settext("<col=ffffff>Loading...</col>");
	cc_setontimer("ballot_list_resetclick(event_com, event_comsubid, $string0, calc(clientclock + 60))");
}
if_script_trigger(-13159379, ballot:list, -1, $int2);
