// 6554
[proc,script6554]
def_int $int0 = 120;
def_int $int1 = 30;
if (~on_mobile = true) {
	$int0, $int1 = 60, 60;
}
if (deviceoption_get(^deviceoption_fps_limit) = 0) {
	deviceoption_set(^deviceoption_fps_limit, $int0);
	deviceoption_set(26, $int1);
} else if (deviceoption_get(26) = 0) {
	deviceoption_set(26, deviceoption_get(^deviceoption_fps_limit));
}
