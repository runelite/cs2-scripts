// 2161
[clientscript,fossil_mushtree_button_keypress](char $keychar0, component $component1, string $string0)
if ($keychar0 = null | ~keypress_permit(fossil_mushtrees, null) = 0) {
	return;
}
if (string_indexof_char($string0, $keychar0) ! -1) {
	~v2_stone_button_in($component1);
	if_setonkey(null, $component1);
	if_setontimer("fossil_mushtree_button_reset($component1, $string0, calc(clientclock + 40))", $component1);
	if_resume_pausebutton($component1);
}
