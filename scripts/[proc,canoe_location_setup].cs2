// 3100
[proc,canoe_location_setup](component $component0, string $string0, int $int1, string $string1, interface $interface2)
if ($int1 = 0) {
	if_setop(1, append("Travel to<col=ff9040> ", $string0), $component0);
	if_setonkey("script7885(event_keychar, $component0, $string1, $interface2)", $component0);
} else {
	if_setop(1, "", $component0);
	if_setonkey(null, $component0);
}
