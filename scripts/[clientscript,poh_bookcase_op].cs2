// 7845
[clientscript,poh_bookcase_op](int $opindex0, component $component1, int $comsubid2, boolean $boolean3)
if ($opindex0 = 1 & cc_find($component1, $comsubid2) = true) {
	cc_settrans(0);
	cc_setonmouserepeat(null);
	cc_setonmouseleave(null);
	cc_setontimer("poh_bookcase_reset(event_com, event_comsubid, calc(clientclock + 20), $boolean3)");
} else {
	sound_synth(interface_select1, 1, 0);
}
