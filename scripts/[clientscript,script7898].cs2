// 7898
[clientscript,script7898]
cc_deleteall(talent_tree:tooltip);
if (%talent_resets_available <= 0) {
	mes("<col=ff0000>You need atleast one pact reset point to do that. You can see which tasks give you these points, within the tasks interface.");
	sound_synth(pillory_wrong, 1, 0);
	return;
}
if_script_trigger(-670389870, talent_tree:perm_floating_panel_content, -1);
