// 7953
[proc,jigsaw_is_complete](dbrow $dbrow0)(int)
def_int $int1 = db_getfieldcount($dbrow0, jigsaw:piece);
def_int $int2 = 0;
def_int $int3 = ~jigsaw_progress_variable($dbrow0);
while ($int2 < $int1) {
	if (testbit($int3, $int2) = ^false) {
		return(0);
	}
	$int2 = calc($int2 + 1);
}
return(1);
