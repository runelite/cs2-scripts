// 4962
[proc,colosseum_intermission_draw_buttons](component $component0, component $component1, int $int2)
def_int $comsubid3 = ~v2_stone_button($component0);
def_string $string0 = "Continue";
def_boolean $boolean4 = ~on_mobile;
def_int $colour5 = 0x00f010;
if (%varcint1194 = 0) {
	$colour5 = 0x9f9f9f;
}
if_setop(1, $string0, $component0);
cc_create($component0, ^iftype_text, $comsubid3, false);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_settext($string0);
cc_settextfont(p12_full);
cc_settextshadow(true);
cc_setcolour($colour5);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
if (%varcint1194 = 0) {
	if_settrans(190, $component0);
}
cc_sethide(false);
if ($boolean4 = false & %varcint1194 ! 0) {
	if_setonmouseleave("colosseum_button_hover($component0, 0, $string0, $colour5)", $component0);
	if_setonmouserepeat("colosseum_button_hover($component0, 1, $string0, $colour5)", $component0);
