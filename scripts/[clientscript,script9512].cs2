// 9512
[clientscript,script9512](int $int0, component $component1, int $comsubid2, int $int3)
if ($int0 = 1 & cc_find($component1, $comsubid2) = true) {
	cc_settrans(140);
	cc_setonmouserepeat(null);
	cc_setonmouseleave(null);
	cc_setonmouseleave(null);
	cc_setontimer("script9513(calc(clientclock + 20), $component1, $comsubid2, $int3)");
}
