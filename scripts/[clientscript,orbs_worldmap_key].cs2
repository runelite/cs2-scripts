// 5141
[clientscript,orbs_worldmap_key](int $key0, component $component1)
if ($key0 ! ^key_m) {
	return;
}
if (%settings_world_map_hotkey_disabled = 1) {
	return;
}
if (keyheld(^key_control_left) = true) {
	if (string_length(if_getop(1, $component1)) > 0) {
		if_triggerop($component1, -1, 1);
	} else {
		if_triggerop($component1, -1, 2);
	}
}
