// 9640
[clientscript,script9640](component $component0, string $string0, int $int1, int $int2, component $component3)
sound_synth(interface_select1, 1, 0);
if_resume_pausebutton($component3);
if_setop(1, "", $component0);
if_setonop("script9638($component0, $string0, 1, 1)", $component0);
if_setonmouserepeat("script9638($component0, $string0, 1, 1)", $component0);
if_setonmouseleave("script9638($component0, $string0, 1, 1)", $component0);
~script9639($component0, $string0, $int1, $int2);
