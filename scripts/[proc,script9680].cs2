// 9680
[proc,script9680](component $component0)
cc_create($component0, ^iftype_rectangle, 0, false);
cc_settrans(255);
cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
cc_setsize(1, 1, ^setsize_abs, ^setsize_abs);
cc_setonstattransmit("herbiboar_helper_stattransmit($component0, stat(hunter), stat(herblore)){hunter, herblore}");
