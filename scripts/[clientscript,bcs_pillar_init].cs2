~bcs_pillar_initbutton_rotate($com_bcs_pillar_rotate_anticlockwise1, "arrows_curved,3", "Rotate Anticlockwise", -1, $com_bcs_pillar_emblem3);
~bcs_pillar_initbutton_confirm($com_bcs_pillar_confirm2, null, "Confirm");
