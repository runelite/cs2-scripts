// 7155
[clientscript,omnishop_main_view_toggle](dbrow $dbrow0, inv $inv1)
if (%omnishop_view_expanded = 1) {
	%omnishop_view_expanded = 0;
} else {
	%omnishop_view_expanded = 1;
}
%omnishop_selected_id = -1;
~omnishop_main_info_setup(
	0 = $dbrow0, 
	1 = $inv1, 
	2 = 0, 
	3 = 0, 
	4 = 0, 
	5 = -1, 
	6 = "", 
	7 = 1, 
	8 = -1
);
~omnishop_main_setup($dbrow0, $inv1, 1);
