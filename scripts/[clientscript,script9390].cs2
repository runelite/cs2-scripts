// 9390
[clientscript,script9390](component $component0, int $comsubid1)
if (cc_find($component0, $comsubid1) = true & cc_find($component0, cc_param(param_2552)) = true) {
	if (calc(clientclock % 40) >= 20) {
		cc_setgraphic("league_6_combat_mastery_small_backing01,2");
		return;
	}
	cc_setgraphic("league_6_combat_mastery_small_backing01,3");
}
