			cc_setop(1, "Examine");
			cc_setonop("cc_settrans_temporarily(event_com, cc_getid, 100, 0)");
			$int11 = calc($int11 + 1);
		} else {
			cc_sethide(true);
		}
		$int10 = calc($int10 + 1);
	}
}
if ($int11 = 0) {
	cc_create($component3, ^iftype_text, $int11, false);
	cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
	cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
